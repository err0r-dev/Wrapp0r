# Wrapp0r Docker Environment Variables
# Copy this file to .env and modify as needed
#
# Usage:
#   cp .env.example .env
#   docker compose up -d

# ============================================
# Port Configuration
# ============================================

# Web server port (nginx frontend)
WEB_PORT=80

# HTTPS port (requires SSL configuration in nginx)
WEB_HTTPS_PORT=443

# API server port
SERVER_PORT=3001

# ============================================
# Security Configuration
# ============================================

# CORS origin for API requests
# - Use * for development/testing
# - Use specific domain for production (e.g., https://wrapp0r.example.com)
CORS_ORIGIN=*

# ============================================
# Runtime Configuration
# ============================================

# Node environment (production/development)
NODE_ENV=production
