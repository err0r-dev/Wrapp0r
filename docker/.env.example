# Wrapp0r Docker Environment Variables
# Copy this file to .env and modify as needed

# Web server port (nginx)
WEB_PORT=80

# Optional HTTPS port (requires additional nginx SSL config)
WEB_HTTPS_PORT=443

# API server port
SERVER_PORT=3001

# CORS origin for API requests
# Use * for development, specific domain for production
CORS_ORIGIN=*

# Node environment
NODE_ENV=production
